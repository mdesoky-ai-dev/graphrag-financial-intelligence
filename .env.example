# ==============================================================================
# graphrag-financial-intelligence  -  environment variables
# Copy to .env and fill in.  Never commit .env.
# ==============================================================================

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
ENV=dev                       # dev | prod
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# AWS Bedrock  (LLM + embeddings)
# Reuse the IAM credentials from Project 1.
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_LLM_MODEL_ID=          # e.g. anthropic.claude-sonnet-<version>
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ------------------------------------------------------------------------------
# Neo4j Aura  (knowledge graph)
# Create a free instance at https://console.neo4j.io
# The connection URI, user, and generated password come from the Aura console.
# ------------------------------------------------------------------------------
NEO4J_URI=                     # neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ------------------------------------------------------------------------------
# Pinecone  (vector store)
# Create a serverless index at https://app.pinecone.io
# Dimensions must match the embedding model (Titan V2 = 1024).
# ------------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX_NAME=financial-docs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ------------------------------------------------------------------------------
# LangSmith  (observability)
# ------------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=graphrag-financial-intelligence
LANGSMITH_TRACING=true

# ------------------------------------------------------------------------------
# Ingestion and retrieval parameters
# ------------------------------------------------------------------------------
EMBEDDING_DIMENSIONS=1024
CHUNK_SIZE=1024
CHUNK_OVERLAP=200

# Entity resolution thresholds.
# If cosine similarity between a new entity and an existing one is:
#   >= ER_MERGE_THRESHOLD          -> auto-merge (treat as same node)
#   <  ER_REJECT_THRESHOLD         -> auto-reject (treat as different)
#   in [reject, merge)             -> LLM adjudicates
ER_MERGE_THRESHOLD=0.87
ER_REJECT_THRESHOLD=0.78
